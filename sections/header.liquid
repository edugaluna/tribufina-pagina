<header class="main-header full-width">
  <div class="header-top">
    <nav class="main-nav">
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
      <a href="{{ routes.search_url }}">🔍 Buscar</a>
    </nav>

    <div class="logo">
      <a href="{{ routes.root_url }}">{{ shop.name }}</a>
    </div>

    <div class="header-right">
      {% if shop.customer_accounts_enabled %}
        <shopify-account menu="{{ section.settings.customer_account_menu }}">
          {{ 'icon-account.svg' | inline_asset_content }}
        </shopify-account>
      {% endif %}

      <a href="{{ routes.cart_url }}">
        🧳 Canasta
        {% if cart.item_count > 0 %}
          <sup>{{ cart.item_count }}</sup>
        {% endif %}
      </a>
    </div>
  </div>
</header>

{% stylesheet %}
  .main-header {
    background-color: var(--dark-green);
    color: var(--white);
    padding: 15px 40px;
  }
  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 14px;
  }
  .logo {
    font-weight: bold;
    font-size: 16px;
    text-align: center;
    flex-grow: 1;
  }
  .logo a {
    color: var(--white);
    text-decoration: none;
  }
  .header-right {
    display: flex;
    gap: 20px;
    align-items: center;
  }
  .header-right a {
    color: var(--white);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .main-nav {
    display: flex;
    gap: 20px;
    font-size: 14px;
  }
  .main-nav a {
    color: var(--white);
    text-decoration: none;
  }
  header sup {
    background: var(--white);
    color: var(--dark-green);
    border-radius: 50%;
    padding: 0 6px;
    font-size: 11px;
    margin-left: 4px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
<footer class="main-footer">
  © {{ 'now' | date: '%Y' }} {{ shop.name }}, {{ powered_by_link }}
</footer>

{% stylesheet %}
  .main-footer {
    background-color: var(--dark-green);
    color: var(--white);
    text-align: center;
    padding: 15px;
    font-size: 12px;
    margin-top: auto;
  }
  .main-footer a {
    color: var(--white);
    text-decoration: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": []
}
{% endschema %}
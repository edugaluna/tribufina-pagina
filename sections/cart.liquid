<div class="cart-container">
  <h1 class="page-title">Carrito</h1>

  {% if cart.item_count > 0 %}
    <div class="cart-items-wrapper">
      {% for item in cart.items %}
        <div class="cart-item">
          {% if item.image %}
            <img
              src="{{ item.image | image_url: width: 140 }}"
              alt="{{ item.product.title }}"
              class="product-image"
              width="140"
              height="187"
            >
          {% else %}
            <div class="product-image-placeholder"></div>
          {% endif %}
          <div class="product-title">{{ item.product.title }}</div>
          <div class="product-sizes">Talla: {{ item.variant.title }}</div>
          <div class="product-price">{{ item.line_price | money }}</div>
          <a href="{{ item.url_to_remove }}" style="font-size: 12px; color: var(--text-muted);">Eliminar</a>
        </div>
      {% endfor %}
    </div>

    <div class="checkout-bar">
      <span>IVA: 16%</span>
      <div class="checkout-box">
        <div class="total-amount">Total: {{ cart.total_price | money }}</div>
        <form action="{{ routes.cart_url }}" method="post">
          <button type="submit" name="checkout" class="btn-buy">Comprar</button>
        </form>
      </div>
    </div>
  {% else %}
    <p style="text-align: center; margin: 40px 0;">Tu carrito está vacío.</p>
    <div style="text-align: center;">
      <a href="{{ routes.all_products_collection_url }}" class="btn-add-cart" style="display: inline-block; text-decoration: none;">
        Seguir comprando
      </a>
    </div>
  {% endif %}

  <hr class="divider">

  <div class="bottom-sections">
    <div>
      <h2 class="column-title">Favoritos</h2>
      <p style="text-align: center; color: var(--text-muted); font-size: 13px;">
        {% if customer %}
          Tus productos favoritos aparecerán aquí.
        {% else %}
          <a href="{{ routes.account_login_url }}" style="color: var(--dark-green);">Inicia sesión</a> para guardar favoritos.
        {% endif %}
      </p>
    </div>
    <div>
      <h2 class="column-title">Te puede interesar</h2>
    </div>
  </div>
</div>

{% stylesheet %}
  .cart-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 20px;
    width: 100%;
  }
  .page-title {
    text-align: center;
    font-size: 28px;
    margin-bottom: 30px;
  }
  .cart-items-wrapper {
    display: flex;
    gap: 20px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .cart-item {
    width: 140px;
    text-align: center;
  }
  .cart-item .product-image {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: 10px;
  }
  .checkout-bar {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 15px;
    margin: 30px 0;
    font-size: 14px;
  }
  .checkout-box {
    border: 1px solid var(--text-dark);
    border-radius: 20px;
    display: flex;
    overflow: hidden;
  }
  .total-amount {
    padding: 8px 20px;
    background: transparent;
  }
  .btn-buy {
    background-color: var(--bg-mint);
    border: none;
    border-left: 1px solid var(--text-dark);
    padding: 8px 25px;
    cursor: pointer;
    font-weight: bold;
  }
  hr.divider {
    border: 0;
    height: 1px;
    background-color: var(--text-muted);
    margin: 20px 0;
    opacity: 0.5;
  }
  .bottom-sections {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-top: 25px;
  }
  .column-title {
    text-align: center;
    font-size: 22px;
    margin-bottom: 20px;
  }
  .btn-add-cart {
    border: 1px solid var(--text-dark);
    background: transparent;
    padding: 12px 30px;
    font-size: 14px;
    cursor: pointer;
    color: var(--text-dark);
  }
  .btn-add-cart:hover {
    background-color: var(--dark-green);
    color: var(--white);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}